{
  "bundles": {
    "marimo": {
      "description": "Marimo AI assistant OpenRouter config (~/.marimo.toml)"
    },
    "cursor": {
      "description": "Cursor global MCP, rules, skills (~/.cursor/)"
    },
    "claude": {
      "description": "Claude Code MCP + settings (~/.claude.json, ~/.claude/settings.json)"
    },
    "opencode": {
      "description": "OpenCode config + LSP (~/.config/opencode/)"
    },
    "goose": {
      "description": "Goose MCP extensions (~/.config/goose/config.yaml)"
    },
    "kilo": {
      "description": "Kilo CLI starter config (~/.config/kilo/kilo.jsonc)"
    },
    "cline": {
      "description": "Cline CLI notes (~/.config/astroai/lab/cline-free.md)"
    },
    "free-models": {
      "description": "OpenRouter + Kilo free-tier model presets for all agents"
    },
    "codex": {
      "description": "Codex CLI MCP (~/.codex/config.toml)"
    },
    "copilot": {
      "description": "GitHub Copilot CLI MCP (~/.copilot/mcp-config.json)"
    },
    "cli": {
      "description": "GitHub token hook + command reminder file (~/.config/astroai/lab/)"
    },
    "project": {
      "description": "Project .cursor/, AGENTS.md, .goosehints in target dir"
    },
    "all": {
      "description": "Default install — all agent backends + GitHub skills + marimo AI",
      "includes": ["cursor", "claude", "opencode", "goose", "codex", "copilot", "cli", "kilo", "free-models", "marimo"]
    }
  },
  "mcp_notes": {
    "context7": "Remote docs — low token cost for library/API lookups",
    "memory": "Persists on /arc via MEMORY_FILE_PATH",
    "github": "Set GITHUB_TOKEN (gh auth login exports it in agent env hook)",
    "fetch": "uvx mcp-server-fetch — no Node required",
    "sequential-thinking": "npx -y @modelcontextprotocol/server-sequential-thinking — step-by-step reasoning",
    "puppeteer": "npx -y @modelcontextprotocol/server-puppeteer — browser console automation",
    "platform_clis": "canfar/cadcget/astroai-lab in /opt/astroai/venv/cadc — upgrade-cadc-tools.sh; project deps use pixi/uv lockfiles under TMP_SRC_DIR"
  }
}
