      "default": true,
      "install": {
        "type": "bundled",
        "note": "Included in agent setup MCP configs"
      }
    },
    {
      "id": "mcp-memory",
      "kind": "mcp",
      "tags": ["lean"],
      "summary": "Persistent agent memory (already in agent setup)",
      "default": true,
      "install": {
        "type": "bundled",
        "note": "Included in agent setup MCP configs"
      }
    },
    {
      "id": "git-mcp",
      "kind": "mcp",
      "tags": ["lean", "review"],
      "summary": "Local git MCP (uvx mcp-server-git) — no API key",
      "install": {
        "type": "mcp-snippet",
        "server": "git",
        "cursor": {
          "command": "uvx",
          "args": ["mcp-server-git"]
        },
        "opencode": {
          "type": "local",
          "command": ["uvx", "mcp-server-git"],
          "enabled": true
        }
      }
    },
    {
      "id": "time",
      "kind": "mcp",
      "tags": ["lean"],
      "summary": "Timezone / time MCP — no API key",
      "install": {
        "type": "mcp-snippet",
        "server": "time",
        "cursor": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-time"]
        },
        "opencode": {
          "type": "local",
          "command": ["npx", "-y", "@modelcontextprotocol/server-time"],
          "enabled": true
        }
      }
    },
    {
      "id": "sqlite",
      "kind": "mcp",
      "tags": ["data", "science"],
      "summary": "SQLite MCP on scratch DB path — no API key",
      "install": {
        "type": "mcp-snippet",
        "server": "sqlite",
        "cursor": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-sqlite",
            "${TMP_SCRATCH_DIR}/astroai-lab-mcp.sqlite"
          ]
        },
        "opencode": {
          "type": "local",
          "command": [
            "npx",
            "-y",
            "@modelcontextprotocol/server-sqlite",
            "${TMP_SCRATCH_DIR}/astroai-lab-mcp.sqlite"
          ],
          "enabled": true
        }
      }
    },
