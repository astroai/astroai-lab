{
  "bundles": {
    "cursor": {
      "description": "Cursor global MCP, rules, skills (~/.cursor/)"
    },
    "claude": {
      "description": "Claude Code MCP + settings (~/.claude.json, ~/.claude/settings.json)"
    },
    "opencode": {
      "description": "OpenCode config + LSP (~/.config/opencode/)"
    },
    "goose": {
      "description": "Goose MCP extensions (~/.config/goose/config.yaml)"
    },
    "kilo": {
      "description": "Kilo CLI starter config (~/.config/kilo/kilo.jsonc)"
    },
    "cline": {
      "description": "Cline CLI notes (~/.config/canfar/lab/cline-free.md)"
    },
    "free-models": {
      "description": "OpenRouter + Kilo free-tier model presets for all agents"
    },
    "codex": {
      "description": "Codex CLI MCP (~/.codex/config.toml)"
    },
    "copilot": {
      "description": "GitHub Copilot CLI MCP (~/.copilot/mcp-config.json)"
    },
    "cli": {
      "description": "GitHub token hook + command reminder file (~/.config/canfar/lab/)"
    },
    "project": {
      "description": "Project .cursor/, AGENTS.md, .goosehints in target dir"
    },
    "all": {
      "description": "Default install — all agent backends + GitHub skills",
      "includes": ["cursor", "claude", "opencode", "goose", "codex", "copilot", "cli", "kilo", "free-models"]
    }
  },
  "mcp_notes": {
    "context7": "Remote docs — low token cost for library/API lookups",
    "memory": "Persists on /arc via MEMORY_FILE_PATH",
    "github": "Set GITHUB_TOKEN (gh auth login exports it in agent env hook)",
    "fetch": "uvx mcp-server-fetch — no Node required"
  }
}
